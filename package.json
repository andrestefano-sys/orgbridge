{
  "name": "orgbridge",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "turbo run db:push --filter=@orgbridge/db",
    "db:studio": "turbo run db:studio --filter=@orgbridge/db",
    "db:generate": "turbo run db:generate --filter=@orgbridge/db",
    "seed:admin": "pnpm --filter @orgbridge/db seed:admin"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
